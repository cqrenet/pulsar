TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ENABLE_PERIODIC_FETCH=false
FETCH_INTERVAL_MINUTES=60

# ---------------------------------------------------------------------------
# MCP server authentication
# ---------------------------------------------------------------------------

# Public hostname(s) accepted in the Host header by the MCP SSE transport.
# Required when running behind a reverse proxy — without this, FastMCP's DNS
# rebinding protection rejects requests with the real hostname.
# Comma-separated, e.g. pulsar.cqre.net or pulsar.cqre.net,pulsar.internal
MCP_ALLOWED_HOSTS=

# API key for the MCP SSE endpoint — recommended for Claude Desktop and AURORA.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Clients send it as:  Authorization: Bearer <key>  or  x-api-key: <key>
# Works alongside AUTH_ENABLED — either a valid API key OR a valid Entra token
# is accepted.  Leave empty to rely solely on AUTH_ENABLED (or no auth at all).
MCP_API_KEY=

# OAuth 2.0 discovery (RFC 8414) — exposes /.well-known/oauth-authorization-server
# so Claude Desktop and AURORA can discover the Entra auth endpoints automatically.
# MCP_CLIENT_ID is the Entra app registration used for the MCP scope.
# AUTH_TENANT_ID (below) is reused as the tenant.  Both must be set to activate.
MCP_CLIENT_ID=

# ---------------------------------------------------------------------------
# OIDC auth to protect the API, UI, and MCP endpoint
# ---------------------------------------------------------------------------
AUTH_ENABLED=false
AUTH_TENANT_ID=your-tenant-id
AUTH_CLIENT_ID=your-api-client-id
# API scope the SPA should request at login.
# Example: api://cc31fd45-1eca-431f-a2c6-ba81cd4c5d50/.default
AUTH_SCOPE=
# Comma-separated lists (optional):
AUTH_ALLOWED_ROLES=
AUTH_ALLOWED_GROUPS=

MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=example
MONGO_PORT=27017

# MongoDB connection string (takes precedence over root credentials in Docker Compose)
MONGO_URI=mongodb://root:example@localhost:27017

# Optional: number of days to retain events in MongoDB (0 = disabled)
RETENTION_DAYS=0

# Optional: comma-separated CORS origins (e.g., http://localhost:3000,https://pulsar.cqre.net)
CORS_ORIGINS=*

# OpenAPI docs exposure (set true only for dev)
DOCS_ENABLED=false

# Valkey/Redis (used for rate limiting)
# In Docker Compose, this is set automatically to redis://redis:6379/0
# For local dev: docker run -d -p 6379:6379 valkey/valkey:8-alpine
REDIS_URL=redis://localhost:6379/0

# Optional: SIEM export webhook (e.g., Splunk HEC, Sentinel, or generic syslog webhook)
SIEM_ENABLED=false
SIEM_WEBHOOK_URL=
# SIEM_ALLOWED_DOMAINS=your-siem.com

# Optional: rule-based alerting during ingestion
ALERTS_ENABLED=false

# Alert notifications (optional)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_FORMAT=generic  # generic | slack | teams
ALERT_DEDUPE_MINUTES=15

# Webhook security (optional but strongly recommended)
# Set this to the same clientState used when creating Graph subscriptions
WEBHOOK_CLIENT_SECRET=

# Optional: privacy / access control
# Hide entire services from users without PRIVACY_SERVICE_ROLES
# PRIVACY_SERVICES=Exchange,Teams
# Hide specific operations from users without PRIVACY_SERVICE_ROLES
# PRIVACY_SENSITIVE_OPERATIONS=MailItemsAccessed,Search-Mailbox,Send,ChatMessageRead
# Comma-separated list of Entra roles that can access privacy-sensitive data
# PRIVACY_SERVICE_ROLES=SecurityAdministrator,ComplianceAdministrator

# Optional: SIEM domain allowlist (comma-separated, supports wildcards)
# SIEM_ALLOWED_DOMAINS=your-siem.com

# Optional: Azure Key Vault for secrets storage
# AZURE_KEY_VAULT_NAME=your-keyvault-name
